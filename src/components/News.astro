---
interface Props {
  date: string;
}

const { date } = Astro.props;
---

<div class="news-item">
  <span class="news-date">{date}</span>
  <div class="news-text"><slot /></div>
</div>

<style>
  .news-item {
    background: var(--surface);
    border: 1px solid var(--border);
    border-left: 3px solid var(--accent);
    border-radius: 8px;
    padding: 1.1rem 1.25rem;
    margin-bottom: 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    transition: box-shadow 0.18s ease;
  }

  .news-item:hover {
    box-shadow: 0 2px 12px var(--accent-shadow);
  }

  .news-date {
    font-size: 0.76rem;
    font-weight: 700;
    color: var(--accent);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .news-text {
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--muted);
  }

  .news-text :global(strong) {
    color: var(--text);
    font-weight: 600;
  }

  .news-text :global(a) {
    color: var(--accent);
    text-decoration: none;
  }

  .news-text :global(a:hover) {
    text-decoration: underline;
  }

  .news-text :global(p) {
    margin: 0 0 0.4rem;
  }

  .news-text :global(p:last-child) {
    margin-bottom: 0;
  }

  .news-text :global(ul) {
    margin: 0.2rem 0 0;
    padding-left: 1.2rem;
  }

  .news-text :global(li) {
    margin-bottom: 0.25rem;
  }
</style>
